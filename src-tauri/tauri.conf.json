{
  "package": {
    "productName": "MuseLocal",
    "version": "1.0.0"
  },
  "build": {
    "devPath": "http://localhost:3000",
    "distDir": "../out",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "tauri": {
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.muselocal.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "externalBin": [
        "binaries/server"
      ]
    },
    "allowlist": {
      "all": true,
      "shell": {
        "all": false,
        "sidecar": true,
        "execute": true,
        "open": true
      }
    },
    "windows": [
      {
        "title": "MuseLocal - Local AI MIDI Studio",
        "width": 1100,
        "height": 780,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
